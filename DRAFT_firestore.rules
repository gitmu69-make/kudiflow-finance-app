rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Public Profile
    function isValidUser(data) {
      return data.keys().hasAll(['createdAt']) &&
             data.keys().size() <= 2 &&
             data.createdAt == request.time &&
             (data.keys().hasOnly(['createdAt', 'displayName']) ? (data.displayName is string && data.displayName.size() <= 100) : true);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Allow searching users (basic)
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName']);
    }

    // User Private Data
    function isValidPrivate(data) {
      return data.keys().hasAll(['phoneNumber']) &&
             data.keys().size() <= 2 &&
             data.phoneNumber is string && data.phoneNumber.size() >= 7 && data.phoneNumber.size() <= 20 &&
             (data.keys().hasOnly(['phoneNumber', 'updatedAt']) ? (data.updatedAt == request.time) : true);
    }

    match /users/{userId}/private/info {
      allow get, write: if isOwner(userId);
    }

    // Transactions
    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'type', 'amount', 'timestamp']) &&
             data.keys().size() <= 6 &&
             data.userId == request.auth.uid &&
             data.type in ['sale', 'expense'] &&
             data.amount is number && data.amount > 0 &&
             data.timestamp == request.time &&
             (data.keys().hasOnly(['userId', 'type', 'amount', 'timestamp', 'category', 'note']) ? 
               ((!data.keys().contains('category') || (data.category is string && data.category.size() <= 50)) &&
                (!data.keys().contains('note') || (data.note is string && data.note.size() <= 500))) : true);
    }

    match /users/{userId}/transactions/{txnId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(txnId) && isValidTransaction(incoming());
      allow update: if isOwner(userId) && isValidTransaction(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'category', 'note', 'type', 'timestamp']);
      allow delete: if isOwner(userId);
    }
  }
}
