{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and settings.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the profile was created."
        }
      },
      "required": ["createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A record of income or expense.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "UID of the user who owns this transaction."
        },
        "type": {
          "type": "string",
          "enum": ["sale", "expense"],
          "description": "The type of transaction."
        },
        "amount": {
          "type": "number",
          "description": "The monetary value in GHS."
        },
        "category": {
          "type": "string",
          "description": "Category tag for the transaction."
        },
        "note": {
          "type": "string",
          "description": "Optional description."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the transaction occurred."
        }
      },
      "required": ["userId", "type", "amount", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Root user profile document."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Subcollection of transactions for a specific user."
    }
  }
}
